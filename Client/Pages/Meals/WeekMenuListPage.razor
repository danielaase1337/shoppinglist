@page "/weekmenus"
@using System.Globalization
@inject HttpClient Http
@inject ISettings Settings
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="card-maincontainer container-sm">

    <div class="card">
        <div class="row align-items-center">
            <div class="col">
                <h2>Ukemeny</h2>
                <p class="text-muted">Planlegg ukens middager</p>
            </div>
            <div class="col-auto">
                <button class="btn btn-success" @onclick="CreateNewMenu" disabled="@_creating">
                    @if (_creating)
                    {
                        <span class="spinner-border spinner-border-sm" role="status"></span>
                    }
                    else
                    {
                        <i class="fas fa-plus"></i>
                    }
                    Ny ukemeny
                </button>
            </div>
        </div>
    </div>

    @if (_menus != null)
    {
        @if (_menus.Any())
        {
            <div class="card">
                <ul class="todo-list">
                    @foreach (var menu in GetSortedMenus())
                    {
                        <li>
                            <div class="parent-horizontal-stack align-items-center">
                                <div class="col clickable-name" style="cursor:pointer;" @onclick="@(() => Navigation.NavigateTo($"/weekmenus/{menu.Id}"))">
                                    @if (_editingId == menu.Id)
                                    {
                                        <input class="form-control form-control-sm" style="max-width:240px"
                                               @bind="_editName" @onclick:stopPropagation="true" />
                                    }
                                    else
                                    {
                                        <strong>@(menu.Name ?? $"Uke {menu.WeekNumber}, {menu.Year}")</strong>
                                        <div class="text-muted"><small>@CountPlannedDays(menu) av 7 dager planlagt</small></div>
                                    }
                                </div>
                                <div class="col-auto d-flex gap-1 align-items-center">
                                    @if (_editingId == menu.Id)
                                    {
                                        <button class="btn btn-sm btn-primary" @onclick="@(() => SaveRename(menu))" @onclick:stopPropagation="true" disabled="@_saving">✓</button>
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="CancelRename" @onclick:stopPropagation="true">✕</button>
                                    }
                                    else
                                    {
                                        @if (menu.IsActive)
                                        {
                                            <span class="badge bg-success">Aktiv</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inaktiv</span>
                                        }
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="@(() => StartRename(menu))" @onclick:stopPropagation="true" title="Endre navn">✏️</button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="@(() => DeleteMenu(menu))" @onclick:stopPropagation="true" title="Slett" disabled="@_saving">🗑️</button>
                                        <i class="fas fa-chevron-right text-muted"></i>
                                    }
                                </div>
                            </div>
                        </li>
                    }
                </ul>
            </div>
        }
        else
        {
            <div class="card">
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> Ingen ukemenyer funnet. Opprett din første!
                </div>
            </div>
        }
    }
    else
    {
        <LoadingComponent></LoadingComponent>
    }

</div>

@code {
    private IList<WeekMenuModel>? _menus;
    private bool _creating = false;
    private string? _editingId;
    private string _editName = "";
    private bool _saving = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _menus = await Http.GetFromJsonAsync<List<WeekMenuModel>>(
                Settings.GetApiUrl(ShoppingListKeysEnum.WeekMenus));
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error loading week menus: {ex.Message}");
            _menus = new List<WeekMenuModel>();
        }
    }

    private IEnumerable<WeekMenuModel> GetSortedMenus()
    {
        if (_menus == null) return Enumerable.Empty<WeekMenuModel>();
        return _menus
            .OrderByDescending(m => m.IsActive)
            .ThenByDescending(m => m.Year)
            .ThenByDescending(m => m.WeekNumber);
    }

    private static int CountPlannedDays(WeekMenuModel menu)
        => menu.DailyMeals?.Count(d => !string.IsNullOrEmpty(d.MealRecipeId)) ?? 0;

    private void StartRename(WeekMenuModel menu)
    {
        _editingId = menu.Id;
        _editName = menu.Name ?? "";
    }

    private void CancelRename()
    {
        _editingId = null;
        _editName = "";
    }

    private async Task SaveRename(WeekMenuModel menu)
    {
        if (string.IsNullOrWhiteSpace(_editName)) return;

        _saving = true;
        var originalName = menu.Name;
        var originalLastModified = menu.LastModified;
        try
        {
            menu.Name = _editName.Trim();
            menu.LastModified = DateTime.UtcNow;
            var response = await Http.PutAsJsonAsync(
                Settings.GetApiUrl(ShoppingListKeysEnum.WeekMenus), menu);

            if (response.IsSuccessStatusCode)
            {
                _editingId = null;
            }
            else
            {
                menu.Name = originalName;
                menu.LastModified = originalLastModified;
                Console.WriteLine($"❌ Rename failed: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            menu.Name = originalName;
            menu.LastModified = originalLastModified;
            Console.WriteLine($"❌ Rename error: {ex.Message}");
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteMenu(WeekMenuModel menu)
    {
        var menuName = menu.Name ?? $"Uke {menu.WeekNumber}, {menu.Year}";
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Slette '{menuName}'?");
        if (!confirmed) return;

        _saving = true;
        try
        {
            var response = await Http.DeleteAsync(
                Settings.GetApiUrlId(ShoppingListKeysEnum.WeekMenu, menu.Id));

            if (response.IsSuccessStatusCode)
            {
                _menus?.Remove(menu);
            }
            else
            {
                Console.WriteLine($"❌ Delete failed: {response.StatusCode}");
            }
        }
         catch (Exception ex)
        {
            Console.WriteLine($"❌ Delete error: {ex.Message}");
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task CreateNewMenu()
    {
        _creating = true;
        try
        {
            var weekNumber = ISOWeek.GetWeekOfYear(DateTime.Now);
            var year = ISOWeek.GetYear(DateTime.Now);

            var newMenu = new WeekMenuModel
            {
                Name = $"Uke {weekNumber} {year}",
                WeekNumber = weekNumber,
                Year = year,
                PlanningStartDate = DateTime.UtcNow,
                IsActive = true,
                LastModified = DateTime.UtcNow
            };

            var response = await Http.PostAsJsonAsync(
                Settings.GetApiUrl(ShoppingListKeysEnum.WeekMenus), newMenu);

            if (response.IsSuccessStatusCode)
            {
                var created = await response.Content.ReadFromJsonAsync<WeekMenuModel>();
                if (!string.IsNullOrEmpty(created?.Id))
                {
                    Navigation.NavigateTo($"/weekmenus/{created.Id}");
                }
                else
                {
                    _menus = await Http.GetFromJsonAsync<List<WeekMenuModel>>(
                        Settings.GetApiUrl(ShoppingListKeysEnum.WeekMenus));
                }
            }
            else
            {
                Console.WriteLine($"❌ Create week menu failed: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error creating week menu: {ex.Message}");
        }
        finally
        {
            _creating = false;
        }
    }
}

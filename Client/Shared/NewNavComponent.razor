@inject NavigationManager Navigation

<nav class="navbar navbar-expand-sm navbar-dark">
    <a class="navbar-brand" href="">The Aase-broen's</a>

    <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#toggler"
            aria-controls="toggler" aria-expanded="false" aria-label="Toggle navigation" @onclick="ToggleNavMenu">
        <span class="navbar-toggler-icon"></span>
    </button>

    <div class="@NavMenuCssClass" id="toggler" @onclick="ToggleNavMenu">
        <ul class="navbar-nav mr-auto mt-2 mt-lg-0">
            <AuthorizeView>
                <Authorized>
                    @if (_planleggingOpen || _adminOpen)
                    {
                        <div class="dropdown-backdrop" @onclick="CloseAllDropdowns" @onclick:stopPropagation="false"></div>
                    }

                    <li class="nav-item">
                        <NavLink class="nav-link" href="/shoppinglist">
                            <span class="oi oi-arrow-circle-right" aria-hidden="true" style="margin:2px"></span> Handleliste
                        </NavLink>
                    </li>

                    <li class="nav-item">
                        <NavLink class="nav-link" href="/weekmenus">
                            <span class="oi oi-calendar" aria-hidden="true" style="margin:2px"></span> Ukesplan
                        </NavLink>
                    </li>

                    <li class="nav-item nav-dropdown @(_planleggingOpen ? "open" : "")">
                        <span class="nav-link dropdown-trigger"
                              role="button"
                              tabindex="0"
                              aria-haspopup="true"
                              aria-expanded="@_planleggingOpen.ToString().ToLower()"
                              @onclick="TogglePlanleggingMenu"
                              @onclick:stopPropagation="true"
                              @onkeydown="HandlePlanleggingKeyDown"
                              @onkeydown:stopPropagation="true">
                            <span class="oi oi-wrench" aria-hidden="true" style="margin:2px"></span> Planlegging <span class="dropdown-arrow">▼</span>
                        </span>
                        <div class="nav-dropdown-menu">
                            <NavLink class="dropdown-item" href="/meals">
                                <span class="oi oi-fork" aria-hidden="true" style="margin:2px"></span> Middager
                            </NavLink>
                            <NavLink class="dropdown-item" href="/frequent-lists">
                                <span class="oi oi-list-rich" aria-hidden="true" style="margin:2px"></span> Hyppige Lister
                            </NavLink>
                            <NavLink class="dropdown-item" href="/inventory">
                                <span class="oi oi-inbox" aria-hidden="true" style="margin:2px"></span> Lager
                            </NavLink>
                        </div>
                    </li>

                    <li class="nav-item nav-dropdown @(_adminOpen ? "open" : "")">
                        <span class="nav-link dropdown-trigger"
                              role="button"
                              tabindex="0"
                              aria-haspopup="true"
                              aria-expanded="@_adminOpen.ToString().ToLower()"
                              @onclick="ToggleAdminMenu"
                              @onclick:stopPropagation="true"
                              @onkeydown="HandleAdminKeyDown"
                              @onkeydown:stopPropagation="true">
                            <span class="oi oi-cog" aria-hidden="true" style="margin:2px"></span> Administrasjon <span class="dropdown-arrow">▼</span>
                        </span>
                        <div class="nav-dropdown-menu">
                            <NavLink class="dropdown-item" href="/familyprofile">
                                <span class="oi oi-people" aria-hidden="true" style="margin:2px"></span> Familieprofil
                            </NavLink>
                            <NavLink class="dropdown-item" href="/managemyshops">
                                <span class="oi oi-arrow-circle-top" aria-hidden="true" style="margin:2px"></span> Håndter butikker
                            </NavLink>
                            <NavLink class="dropdown-item" href="/items">
                                <span class="oi oi-list" aria-hidden="true" style="margin:2px"></span> Administrer varer
                            </NavLink>
                            <NavLink class="dropdown-item" href="/categories">
                                <span class="oi oi-tags" aria-hidden="true" style="margin:2px"></span> Administrer kategorier
                            </NavLink>
                        </div>
                    </li>

                    <li class="nav-item">
                        <span class="nav-link nav-user">👤 @context.User.Identity?.Name</span>
                    </li>
                    <li class="nav-item">
                        <a href="/.auth/logout?post_logout_redirect_uri=/" class="nav-link">
                            🚪 Logg ut
                        </a>
                    </li>
                </Authorized>
                <NotAuthorized>
                    <li class="nav-item">
                        <a href="/.auth/login/aad?post_login_redirect_uri=/" class="nav-link">
                            🔒 Logg inn
                        </a>
                    </li>
                </NotAuthorized>
            </AuthorizeView>
        </ul>
    </div>
</nav>

@code {
    private bool collapseNavMenu = true;
    private bool _planleggingOpen;
    private bool _adminOpen;

    private string NavMenuCssClass => collapseNavMenu ? "collapse navbar-collapse" : "navbar-collapse";

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
        if (collapseNavMenu)
        {
            CloseAllDropdowns();
        }
    }

    private void TogglePlanleggingMenu()
    {
        _planleggingOpen = !_planleggingOpen;
        if (_planleggingOpen)
        {
            _adminOpen = false;
        }
    }

    private void ToggleAdminMenu()
    {
        _adminOpen = !_adminOpen;
        if (_adminOpen)
        {
            _planleggingOpen = false;
        }
    }

    private void ClosePlanleggingMenu()
    {
        _planleggingOpen = false;
    }

    private void CloseAdminMenu()
    {
        _adminOpen = false;
    }

    private void CloseAllDropdowns()
    {
        ClosePlanleggingMenu();
        CloseAdminMenu();
    }

    private void HandlePlanleggingKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "Enter":
            case " ":
            case "Spacebar":
                TogglePlanleggingMenu();
                break;
            case "Escape":
                ClosePlanleggingMenu();
                break;
        }
    }

    private void HandleAdminKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "Enter":
            case " ":
            case "Spacebar":
                ToggleAdminMenu();
                break;
            case "Escape":
                CloseAdminMenu();
                break;
        }
    }
}

<div class="@OneShoppingListItem.CssComleteEditClassName">
    <input class="toggle" type="checkbox" value="@OneShoppingListItem.IsDone" @onchange="@(f => VareCheckd(OneShoppingListItem, f))" />

    <label>
        @OneShoppingListItem.Varen.Name
    </label>
    @{
        var _qty = OneShoppingListItem.Varen?.StandardPurchaseQuantity ?? 0;
        var _unit = OneShoppingListItem.Varen?.StandardPurchaseUnit;
        var _hasPackageInfo = _qty > 0 && !string.IsNullOrEmpty(_unit);
        var _pkgLabel = _hasPackageInfo ? $"× {_qty.ToString("G29")}{_unit}" : null;
    }
    <span class="qty-display">
        <input @bind-value="OneShoppingListItem.Mengde" class="@(_hasPackageInfo ? "qty-input-narrow" : "")" />
        @if (_hasPackageInfo)
        {
            <span class="pkg-size-label" title="@($"{OneShoppingListItem.Mengde} × {_qty.ToString("G29")}{_unit}")">@_pkgLabel</span>
        }
    </span>
    <button class="btn btn-sm btn-outline-danger" @onclick="@(e => DeleteVare(OneShoppingListItem))"><i class="fas fa-ban"> </i></button>

</div>

@code
{


    [Parameter]
    public ShoppingListItemModel OneShoppingListItem { get; set; }

    [Parameter]
    public EventCallback DeleteVareCallback { get; set; }

    public async Task DeleteVare(ShoppingListItemModel shoppingListItem)
    {
        await DeleteVareCallback.InvokeAsync(shoppingListItem);
    }



    private void VareCheckd(ShoppingListItemModel l, Microsoft.AspNetCore.Components.ChangeEventArgs value)
    {
        if (value?.Value != null && value.Value is bool bValue)
            l.IsDone = bValue;
    }
    

}